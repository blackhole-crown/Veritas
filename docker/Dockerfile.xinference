# Dockerfile.xinference
FROM nvidia/cuda:12.8.0-runtime-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive

# 安装基础工具
RUN apt-get update && apt-get install -y \
    wget git build-essential curl vim tzdata \
    && ln -fs /usr/share/zoneinfo/Asia/Shanghai /etc/localtime \
    && dpkg-reconfigure --frontend noninteractive tzdata \
    && rm -rf /var/lib/apt/lists/*

# pip换源（清华源）
RUN pip config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple && \
    pip config set global.trusted-host mirrors.tuna.tsinghua.edu.cn

# 安装Miniconda
RUN mkdir -p ~/miniconda3 && \
    wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O ~/miniconda3/miniconda.sh && \
    bash ~/miniconda3/miniconda.sh -b -u -p ~/miniconda3 && \
    rm -rf ~/miniconda3/miniconda.sh

ENV PATH /root/miniconda3/bin:$PATH
RUN echo 'source /root/miniconda3/etc/profile.d/conda.sh' >> ~/.bashrc

# 接受 Anaconda 服务条款
RUN conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main && \
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r && \
    conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/msys2

WORKDIR /app

# 创建 xinference 环境并安装指定版本的包
RUN conda create -n xinference python=3.10.9 -y && \
    /bin/bash -c "source /root/miniconda3/etc/profile.d/conda.sh && \
    conda activate xinference && \
    pip install xinference[transformers]==1.10.0 && \
    pip install sentence-transformers==5.1.1 && \
    pip install torch==2.8.0 torchvision==0.23.0 && \
    pip install transformers==4.56.2 && \
    pip install accelerate==1.10.1 && \
    pip install modelscope==1.30.0 && \
    pip install numpy==2.2.6 && \
    pip install pandas==2.3.2 && \
    pip install scikit-learn==1.7.2"

# 复制 xinference 相关脚本
COPY run_model/Gte-Qwen-2B/ /app/run_model/Gte-Qwen-2B/
COPY run_model/nohup/Xinference/ /app/run_model/nohup/Xinference/

# 设置工作目录
WORKDIR /app/run_model/Gte-Qwen-2B

# 默认命令
CMD ["/bin/bash"]